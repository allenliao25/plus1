# Copy to .env.local and fill in real values. Never commit secrets.

# --- Supabase (client) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI quest creator (server-only; never use NEXT_PUBLIC_*) ---
# Used by app/api/ai/quest-draft and app/api/ai/flyer-to-quest.
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini (multimodal, handles text + flyer images).
OPENAI_MODEL=gpt-4o-mini
