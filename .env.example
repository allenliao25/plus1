# Copy to .env.local and fill in real values. Never commit secrets.

# --- Supabase (client) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://plus1-livid.vercel.app

# --- One-off admin scripts (server-only; never use NEXT_PUBLIC_*) ---
# Required only for npm run seed:demo:prod and npm run seed:demo:cleanup.
SUPABASE_SERVICE_ROLE_KEY=
# Optional. Defaults to looking for mnijungkook, bawllen_, then allen.b042c128.
PLUS1_DEMO_OWNER_HANDLE=

# --- Supabase RLS integration tests (test users only) ---
# Required only when you want npm run test to execute lib/questService.test.mjs
# instead of skipping the database-backed RLS checks.
PLUS1_TEST_PASSWORD=
PLUS1_TEST_EMAIL_HOST=
PLUS1_TEST_EMAIL_JOINER=
PLUS1_TEST_EMAIL_THIRD=

# --- Analytics + crash reporting (client; all optional) ---
# When these are unset, PostHog and Sentry stay dormant (no-op) — matches the
# OPENAI_API_KEY pattern. Set them to turn telemetry on.
# PostHog product analytics (share/guest-RSVP funnel + auth/quest events).
NEXT_PUBLIC_POSTHOG_KEY=
# Optional. Defaults to https://us.i.posthog.com.
NEXT_PUBLIC_POSTHOG_HOST=
# Sentry crash/error reporting (browser SDK, errors only).
NEXT_PUBLIC_SENTRY_DSN=

# --- AI quest creator (server-only; never use NEXT_PUBLIC_*) ---
# Used by app/api/ai/quest-draft and app/api/ai/flyer-to-quest.
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini (multimodal, handles text + flyer images).
OPENAI_MODEL=gpt-4o-mini
